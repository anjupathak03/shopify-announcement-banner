SHOPIFY_API_KEY=replace-with-client-id
SHOPIFY_API_SECRET=replace-with-client-secret
SHOPIFY_API_VERSION=2026-04
SCOPES=write_products,read_themes

# Local development example:
# HOST=https://your-cloudflare-tunnel.trycloudflare.com
# Production example:
# HOST=https://your-render-service.onrender.com
HOST=http://localhost:3000

# If using Docker Compose from this repo:
MONGODB_URI=mongodb://admin:password@127.0.0.1:27017
MONGODB_DB_NAME=shopify_announcement_banner
NODE_ENV=development
